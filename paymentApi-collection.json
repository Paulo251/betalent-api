{
    "info": {
        "name": "BeTalent API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000/api"
        },
        {
            "key": "token",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var json = pm.response.json();",
                                    "pm.collectionVariables.set('token', json.token);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@betalent.com\",\n    \"password\": \"password\"\n}"
                        },
                        "url": "{{base_url}}/login"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/logout"
                    }
                }
            ]
        },
        {
            "name": "Purchase",
            "item": [
                {
                    "name": "Realizar Compra",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"amount\": 1000,\n    \"name\": \"Tester\",\n    \"email\": \"tester@email.com\",\n    \"card_number\": \"5569000000006063\",\n    \"cvv\": \"010\"\n}"
                        },
                        "url": "{{base_url}}/purchase"
                    }
                }
            ]
        },
        {
            "name": "Transactions",
            "item": [
                {
                    "name": "Listar Transações",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/transactions"
                    }
                },
                {
                    "name": "Detalhe da Transação",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/transactions/1"
                    }
                },
                {
                    "name": "Reembolso",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/transactions/1/refund"
                    }
                }
            ]
        },
        {
            "name": "Clients",
            "item": [
                {
                    "name": "Listar Clientes",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/clients"
                    }
                },
                {
                    "name": "Detalhe do Cliente",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/clients/1"
                    }
                }
            ]
        },
        {
            "name": "Gateways",
            "item": [
                {
                    "name": "Ativar/Desativar Gateway",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/gateways/1/toggle"
                    }
                },
                {
                    "name": "Alterar Prioridade",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"priority\": 2\n}"
                        },
                        "url": "{{base_url}}/gateways/1/priority"
                    }
                }
            ]
        },
        {
            "name": "Products",
            "item": [
                {
                    "name": "Listar Produtos",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/products"
                    }
                },
                {
                    "name": "Criar Produto",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Produto Teste\",\n    \"amount\": 500\n}"
                        },
                        "url": "{{base_url}}/products"
                    }
                },
                {
                    "name": "Detalhe do Produto",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/products/1"
                    }
                },
                {
                    "name": "Atualizar Produto",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Produto Atualizado\",\n    \"amount\": 750\n}"
                        },
                        "url": "{{base_url}}/products/1"
                    }
                },
                {
                    "name": "Deletar Produto",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/products/1"
                    }
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "Listar Usuários",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/users"
                    }
                },
                {
                    "name": "Criar Usuário",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Novo Usuário\",\n    \"email\": \"novo@betalent.com\",\n    \"password\": \"123456\",\n    \"role\": \"user\"\n}"
                        },
                        "url": "{{base_url}}/users"
                    }
                },
                {
                    "name": "Detalhe do Usuário",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/users/1"
                    }
                },
                {
                    "name": "Atualizar Usuário",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Usuário Atualizado\",\n    \"role\": \"manager\"\n}"
                        },
                        "url": "{{base_url}}/users/1"
                    }
                },
                {
                    "name": "Deletar Usuário",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": "{{base_url}}/users/1"
                    }
                }
            ]
        }
    ]
}
